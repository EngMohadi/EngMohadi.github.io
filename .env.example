# ============================================================
# Contact backend configuration — PLACEHOLDERS ONLY.
# Never commit real values. Copy to .env and fill locally.
#
# NOTE: The current site is fully static (GitHub Pages), so these
# variables are NOT used yet. They document the configuration a
# future backend / serverless function (Cloudflare Worker, Vercel
# API route, Netlify Function, …) would need in order to truly hide
# contact details and deliver inquiry-form messages server-side.
# Until then, the static site uses obfuscated click-time links
# (see the CONTACT comment in app.js).
# ============================================================

# WhatsApp number in international format, digits only (e.g. 9725XXXXXXXX)
WHATSAPP_PHONE_NUMBER=

# Telegram bot used to deliver inquiry messages to you
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Where inquiry emails should be delivered
CONTACT_EMAIL_TO=

# SMTP server used to send inquiry emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
